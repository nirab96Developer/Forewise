{
  "ci": {
    "collect": {
      "url": ["http://localhost:5173/", "http://localhost:5173/projects"],
      "numberOfRuns": 2
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.80 }],
        "categories:accessibility": ["warn", { "minScore": 0.90 }]
      }
    },
    "upload": { "target": "filesystem", "outputDir": "./lhci-report" }
  }
}
