{
  "name": "kkl-time-report",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"cross-env NODE_ENV=development BROWSER=none npm run dev\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:preview": "electron .",
    "cy:open": "cypress open",
    "cy:run": "cypress run"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.18",
    "@playwright/test": "^1.58.2",
    "@radix-ui/react-icons": "^1.3.0",
    "@react-google-maps/api": "^2.20.7",
    "@sentry/react": "^10.42.0",
    "@tanstack/react-query": "^5.90.7",
    "@types/leaflet": "^1.9.21",
    "allure-playwright": "^3.5.0",
    "axios": "^1.8.3",
    "dayjs": "^1.11.19",
    "dotenv": "^16.4.1",
    "framer-motion": "^12.23.24",
    "html5-qrcode": "^2.3.8",
    "i18next": "^25.6.1",
    "ky": "^1.14.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.482.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.2.4",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^6.30.0",
    "react-toastify": "^11.0.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@applitools/eyes-cypress": "^3.57.3",
    "@tailwindcss/forms": "^0.5.10",
    "@testing-library/cypress": "^10.1.0",
    "@types/google-maps-react": "^2.0.5",
    "@types/node": "^20.19.30",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "cypress": "13.7.3",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-reload": "^2.0.0-alpha.1",
    "playwright": "^1.58.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.3",
    "vite": "^6.0.11",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.kkl.timereport",
    "productName": "KKL Time Report",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/logo-kkl-transparent.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KKL Time Report"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/logo-kkl-transparent.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/logo-kkl-transparent.png"
    }
  }
}
