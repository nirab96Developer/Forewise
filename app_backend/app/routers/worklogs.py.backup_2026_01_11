# app/routers/worklogs.py
"""
Worklog management endpoints - אישור דיווח שעות
מערכת קק"ל - פורמט רשמי

Endpoints:
- GET /worklogs - רשימת דיווחים
- GET /worklogs/{id} - דיווח ספציפי
- POST /worklogs - יצירת דיווח חדש
- PUT /worklogs/{id} - עדכון דיווח
- DELETE /worklogs/{id} - מחיקת דיווח
- POST /worklogs/{id}/submit - הגשה לאישור
- POST /worklogs/{id}/approve - אישור
- POST /worklogs/{id}/reject - דחייה
- GET /worklogs/pending-approval - דיווחים ממתינים לאישור
- GET /worklogs/my-worklogs - הדיווחים שלי
- GET /worklogs/statistics - סטטיסטיקות
"""
from typing import List, Optional
from datetime import date
from fastapi import APIRouter, Depends, HTTPException, Query, status, BackgroundTasks
from sqlalchemy.orm import Session

from app.core.database import get_db
from app.core.dependencies import get_current_active_user
from app.models.user import User
from app.schemas.worklog import (
    WorklogCreate,
    WorklogUpdate,
    WorklogResponse,
    WorklogFilter,
    WorklogSubmit,
    WorklogApprove,
    WorklogReject,
    WorklogListResponse,
    WorklogSegmentResponse,
)
from app.services.worklog_service import WorklogService
from app.core.email import send_email
from app.core.config import settings

router = APIRouter(prefix="/worklogs", tags=["Worklogs - אישור דיווח שעות"])
worklog_service = WorklogService()


def worklog_to_response(worklog) -> WorklogResponse:
    """Convert worklog model to response with all computed fields."""
    segments = []
    if worklog.segments:
        for seg in worklog.segments:
            segments.append(WorklogSegmentResponse(
                id=seg.id,
                worklog_id=seg.worklog_id,
                segment_number=seg.segment_number,
                segment_type=seg.segment_type or "work",
                start_time=seg.start_time,
                end_time=seg.end_time,
                work_minutes=seg.work_minutes,
                break_minutes=seg.break_minutes or 0,
                activity=getattr(seg, 'activity', None),
                created_at=seg.created_at,
                duration_formatted=seg.duration_formatted if hasattr(
                    seg, 'duration_formatted') else None,
                work_hours_decimal=seg.work_hours_decimal if hasattr(
                    seg, 'work_hours_decimal') else None,
                break_hours_decimal=seg.break_hours_decimal if hasattr(
                    seg, 'break_hours_decimal') else None,
            ))

    return WorklogResponse(
        id=worklog.id,
        report_number=worklog.report_number,
        work_order_id=worklog.work_order_id,
        user_id=worklog.user_id,
        project_id=worklog.project_id,
        equipment_id=worklog.equipment_id,
        supplier_id=worklog.supplier_id,
        area_id=worklog.area_id,
        report_date=worklog.report_date,
        start_time=worklog.start_time,
        end_time=worklog.end_time,
        work_hours=worklog.work_hours,
        break_hours=worklog.break_hours,
        total_hours=worklog.total_hours,
        work_type=worklog.work_type,
        activity_description=worklog.activity_description,
        equipment_type=worklog.equipment_type,
        is_standard=worklog.is_standard,
        non_standard_reason=worklog.non_standard_reason,
        notes=worklog.notes,
        status=worklog.status,
        submitted_at=worklog.submitted_at,
        submitted_by_id=worklog.submitted_by_id,
        approved_by_user_id=worklog.approved_by_user_id,
        approved_at=worklog.approved_at,
        rejection_reason=worklog.rejection_reason,
        sent_to_supplier=worklog.sent_to_supplier,
        sent_to_supplier_at=worklog.sent_to_supplier_at,
        sent_to_accountant=worklog.sent_to_accountant,
        sent_to_accountant_at=worklog.sent_to_accountant_at,
        sent_to_area_manager=worklog.sent_to_area_manager,
        sent_to_area_manager_at=worklog.sent_to_area_manager_at,
        equipment_scanned=worklog.equipment_scanned,
        scan_time=worklog.scan_time,
        # Pricing snapshot
        hourly_rate_snapshot=worklog.hourly_rate_snapshot,
        rate_source=worklog.rate_source,
        rate_source_name=worklog.rate_source_name,
        cost_before_vat=worklog.cost_before_vat,
        vat_rate=worklog.vat_rate,
        cost_with_vat=worklog.cost_with_vat,
        # Timestamps
        created_at=worklog.created_at,
        updated_at=worklog.updated_at,
        # Computed properties
        report_number_formatted=worklog.report_number_formatted,
        is_approved=worklog.is_approved,
        is_submitted=worklog.is_submitted,
        is_rejected=worklog.is_rejected,
        is_editable=worklog.is_editable,
        net_hours=worklog.net_hours,
        requires_reason=worklog.requires_reason,
        # Relationship data
        work_order_number=worklog.work_order.order_number if worklog.work_order else None,
        work_order_title=worklog.work_order.title if worklog.work_order else None,
        user_name=worklog.user.full_name if worklog.user and hasattr(
            worklog.user, 'full_name') else None,
        project_name=worklog.project.name if worklog.project else None,
        equipment_name=worklog.equipment.name if worklog.equipment else None,
        equipment_code=worklog.equipment.code if worklog.equipment else None,
        supplier_name=worklog.supplier.name if worklog.supplier else None,
        area_name=worklog.area.name if worklog.area else None,
        approved_by_name=worklog.approved_by.full_name if worklog.approved_by and hasattr(
            worklog.approved_by, 'full_name') else None,
        submitted_by_name=worklog.submitted_by.full_name if worklog.submitted_by and hasattr(
            worklog.submitted_by, 'full_name') else None,
        segments=segments,
    )


