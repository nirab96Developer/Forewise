@router.get("", response_model=List[WorklogResponse])
async def list_worklogs(
    skip: int = Query(0, ge=0),
    limit: int = Query(100, ge=1, le=1000),
    status: Optional[str] = None,
    work_order_id: Optional[int] = None,
    user_id: Optional[int] = None,
    project_id: Optional[int] = None,
    equipment_id: Optional[int] = None,
    supplier_id: Optional[int] = None,
    area_id: Optional[int] = None,
    report_date_from: Optional[date] = None,
    report_date_to: Optional[date] = None,
    is_standard: Optional[bool] = None,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_active_user),
):
    """
    Get list of worklogs with filters.

    רשימת דיווחי שעות עם אפשרויות סינון
    """
    try:
        worklogs = worklog_service.get_worklogs(
            db=db,
            skip=skip,
            limit=limit,
            status=status,
            work_order_id=work_order_id,
            user_id=user_id,
            project_id=project_id,
            equipment_id=equipment_id,
            supplier_id=supplier_id,
            area_id=area_id,
            report_date_from=report_date_from,
            report_date_to=report_date_to,
            is_standard=is_standard,
        )
        return [worklog_to_response(w) for w in worklogs]
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


