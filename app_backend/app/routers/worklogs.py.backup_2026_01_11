    worklog: WorklogCreate,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_active_user),
):
    """
    Create new worklog.

    יצירת דיווח שעות חדש

    תקן: מספיק לשלוח total_hours, המערכת תייצר segments אוטומטית
    לא-תקן: חובה לשלוח segments ו-non_standard_reason
    """
    try:
        created = worklog_service.create_worklog(db, worklog, current_user.id)
        return worklog_to_response(created)
    except ValueError as e:
        raise HTTPException(status_code=400, detail=str(e))
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


