@router.get("/export/excel")
async def export_worklogs_to_excel(
    status: Optional[str] = Query(None, description="Filter by status"),
    date_from: Optional[str] = Query(None, description="Start date (YYYY-MM-DD)"),
    date_to: Optional[str] = Query(None, description="End date (YYYY-MM-DD)"),
    area_id: Optional[int] = Query(None, description="Filter by area"),
    supplier_id: Optional[int] = Query(None, description="Filter by supplier"),
    project_id: Optional[int] = Query(None, description="Filter by project"),
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_active_user),
):
    """
    Export worklogs to Excel file.
    Returns XLSX file for download.
    """
    import io
    from fastapi.responses import StreamingResponse

    try:
        import pandas as pd
    except ImportError:
        raise HTTPException(
            status_code=500, 
            detail="pandas not installed. Run: pip install pandas openpyxl"
        )

    # Get worklogs with filters
    worklogs = worklog_service.get_worklogs(
        db,
        status=status,
        area_id=area_id or current_user.area_id,  # Default to user's area
        supplier_id=supplier_id,
        project_id=project_id,
        skip=0,
        limit=10000,  # Large limit for export
        current_user=current_user,
    )

    # Filter by date if provided
    if date_from or date_to:
        filtered = []
        for w in worklogs:
            w_date = str(w.report_date)
            if date_from and w_date < date_from:
                continue
            if date_to and w_date > date_to:
                continue
            filtered.append(w)
        worklogs = filtered

    # Convert to DataFrame
    data = []
    for w in worklogs:
        data.append({
            'מספר דיווח': w.report_number_formatted if hasattr(w, 'report_number_formatted') else f"WR-{w.report_number}",
            'תאריך': str(w.report_date),
            'סוג': 'תקן' if w.is_standard else 'לא-תקן',
            'שעות עבודה': float(w.work_hours) if w.work_hours else 0,
            'שעות הפסקה': float(w.break_hours) if w.break_hours else 0,
            'סה"כ שעות': float(w.total_hours) if w.total_hours else 0,
            'פרויקט': w.project.name if w.project else '',
            'ספק': w.supplier.name if w.supplier else '',
            'כלי': w.equipment.code if w.equipment else '',
            'סוג כלי': w.equipment_type or '',
            'סטטוס': w.status or '',
            'מנהל עבודה': w.user.full_name if w.user else '',
            'מאשר': w.approved_by.full_name if w.approved_by else '',
            'תאריך אישור': str(w.approved_at) if w.approved_at else '',
            'נימוק (אם לא-תקן)': w.non_standard_reason or '',
        })

    df = pd.DataFrame(data)

    # Create Excel file in memory
    output = io.BytesIO()
    with pd.ExcelWriter(output, engine='openpyxl') as writer:
        df.to_excel(writer, index=False, sheet_name='דיווחי שעות')

        # Auto-adjust column widths
        worksheet = writer.sheets['דיווחי שעות']
        for column in worksheet.columns:
            max_length = 0
            column_letter = column[0].column_letter
            for cell in column:
                try:
                    if len(str(cell.value)) > max_length:
                        max_length = len(str(cell.value))
                except:
                    pass
            adjusted_width = min(50, max(12, max_length + 2))
            worksheet.column_dimensions[column_letter].width = adjusted_width

    output.seek(0)

    # Generate filename
    filename = f"worklogs_{date_from or 'all'}_{date_to or 'all'}.xlsx"

    return StreamingResponse(
        output,
        media_type="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
        headers={
            "Content-Disposition": f"attachment; filename={filename}"
        }
    )
