@router.post("/{worklog_id}/submit", response_model=WorklogResponse)
async def submit_worklog(
    worklog_id: int,
    data: WorklogSubmit = None,
    background_tasks: BackgroundTasks = None,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_active_user),
):
    """
    Submit worklog for approval.

    הגשת דיווח לאישור
    """
    try:
        submitted = worklog_service.submit_worklog(db, worklog_id, current_user.id, data)
        if not submitted:
            raise HTTPException(status_code=404, detail="דיווח לא נמצא")

        # Send notification email in background
        if background_tasks:
            background_tasks.add_task(
                send_submission_notification,
                db, submitted, current_user
            )

        return worklog_to_response(submitted)
    except ValueError as e:
        raise HTTPException(status_code=400, detail=str(e))
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@router.post("/{worklog_id}/approve", response_model=WorklogResponse)
async def approve_worklog(
    worklog_id: int,
    data: WorklogApprove = None,
    background_tasks: BackgroundTasks = None,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_active_user),
):
    """
    Approve worklog.

    אישור דיווח שעות

    נשלח ל:
    - ספק (לעיון בלבד, ללא סכומים)
    - מנהלת חשבונות אזורית (כל הנתונים)
    - מנהל אזור
    - מנהל עבודה בשטח
    """
    try:
        approved = worklog_service.approve_worklog(db, worklog_id, current_user.id, data)
        if not approved:
            raise HTTPException(status_code=404, detail="דיווח לא נמצא")

        # Send notification emails in background
        if background_tasks:
            background_tasks.add_task(
                send_approval_notifications,
                db, approved, current_user
            )

        return worklog_to_response(approved)
    except ValueError as e:
        raise HTTPException(status_code=400, detail=str(e))
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@router.post("/{worklog_id}/reject", response_model=WorklogResponse)
async def reject_worklog(
    worklog_id: int,
    data: WorklogReject,
    background_tasks: BackgroundTasks = None,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_active_user),
):
    """
    Reject worklog.

    דחיית דיווח שעות (חובה סיבה)
    """
    try:
        rejected = worklog_service.reject_worklog(db, worklog_id, current_user.id, data)
        if not rejected:
            raise HTTPException(status_code=404, detail="דיווח לא נמצא")

        # Send rejection notification in background
        if background_tasks:
            background_tasks.add_task(
                send_rejection_notification,
                db, rejected, current_user, data.rejection_reason
            )

        return worklog_to_response(rejected)
    except ValueError as e:
        raise HTTPException(status_code=400, detail=str(e))
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


