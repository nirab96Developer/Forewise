    worklog_id: int,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_active_user),
):
    """
    Get worklog by ID.

    קבלת דיווח לפי מזהה
    """
    worklog = worklog_service.get_worklog(db, worklog_id)
