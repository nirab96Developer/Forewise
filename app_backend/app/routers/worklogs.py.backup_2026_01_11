async def send_submission_notification(db: Session, worklog, submitted_by: User):
    """Send email notification when worklog is submitted."""
    try:
        subject = f"דיווח שעות חדש להגשה - {worklog.report_number_formatted}"
        body = f"""
דיווח שעות חדש הוגש לאישור:

מספר דיווח: {worklog.report_number_formatted}
תאריך: {worklog.report_date}
סוג: {'תקן' if worklog.is_standard else 'לא-תקן'}
שעות: {worklog.total_hours}
הוגש ע"י: {submitted_by.full_name if hasattr(submitted_by, 'full_name') else submitted_by.username}

{'נימוק חריגה: ' + worklog.non_standard_reason if not worklog.is_standard else ''}

לצפייה במערכת: {settings.FRONTEND_URL or 'http://localhost:5173'}/#/worklogs/{worklog.id}
"""
        # Send to approvers (area manager, accountant)
        # This is a placeholder - implement actual recipient lookup
        send_email(to="approver@example.com", subject=subject, body=body)
    except Exception as e:
        print(f"[WARN] Failed to send submission notification: {e}")


