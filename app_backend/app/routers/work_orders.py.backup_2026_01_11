@router.get("/coordination/stats")
def get_coordination_stats(
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_active_user)
):
    """Get work order coordination statistics - Order Coordinator"""
    from sqlalchemy import func
    
    # Count by status
    total_pending = db.query(WorkOrder).filter(
        WorkOrder.status.in_(['PENDING', 'SENT', 'pending', 'sent'])
    ).count()
    
    awaiting_response = db.query(WorkOrder).filter(
        WorkOrder.status.in_(['SENT', 'sent'])
    ).count()
    
    rejected = db.query(WorkOrder).filter(
        WorkOrder.status.in_(['rejected', 'REJECTED'])
    ).count()
    
    # Calculate expired (sent more than 3 hours ago without response)
    expired_threshold = datetime.utcnow() - timedelta(hours=3)
    expired = db.query(WorkOrder).filter(
        WorkOrder.status.in_(['SENT', 'sent']),
        WorkOrder.portal_token_expires < datetime.utcnow()
    ).count()
    
    # Calculate needs escalation (pending more than 3 days)
    escalation_threshold = datetime.utcnow() - timedelta(days=3)
    needs_escalation = db.query(WorkOrder).filter(
        WorkOrder.status.in_(['PENDING', 'SENT', 'pending', 'sent']),
        WorkOrder.created_at < escalation_threshold
    ).count()
    
    return {
        "total_pending": total_pending,
        "awaiting_response": awaiting_response,
        "rejected": rejected,
        "expired": expired,
        "needs_escalation": needs_escalation
    }

