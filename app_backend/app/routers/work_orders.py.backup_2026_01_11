    work_order_id: int,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_active_user)
):
    """Move work order to next supplier - Order Coordinator action"""
    from app.models.work_order_coordination_log import WorkOrderCoordinationLog
    
    work_order = db.query(WorkOrder).filter(WorkOrder.id == work_order_id).first()
    if not work_order:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="הזמנה לא נמצאה"
        )
    
    # Store old supplier info
    old_supplier_id = work_order.supplier_id
    old_supplier = db.query(Supplier).filter(Supplier.id == old_supplier_id).first() if old_supplier_id else None
    
    # Get next available supplier (basic logic - can be enhanced)
    # For now, just get any other active supplier of same type
    next_supplier = db.query(Supplier).filter(
        Supplier.id != old_supplier_id,
        Supplier.is_active == True
    ).first()
    
    if not next_supplier:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="לא נמצא ספק חלופי זמין"
        )
    
    # Update work order
    work_order.supplier_id = next_supplier.id
    work_order.portal_token = secrets.token_urlsafe(32)
    work_order.portal_token_expires = datetime.utcnow() + timedelta(hours=3)
    work_order.status = "SENT"
    work_order.updated_at = datetime.utcnow()
    
