    work_order_id: int,
    work_order_update: WorkOrderUpdate,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_active_user)
):
    """Update a work order."""
    work_order = db.query(WorkOrder).filter(WorkOrder.id == work_order_id).first()
    if not work_order:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="Work order not found"
        )
    
    # Update fields
    update_data = work_order_update.dict(exclude_unset=True)
    for field, value in update_data.items():
        setattr(work_order, field, value)
    
    work_order.updated_at = datetime.utcnow()
    
    db.commit()
    db.refresh(work_order)
    
    # Add project and supplier names
    if work_order.project_id:
        project = db.query(Project).filter(Project.id == work_order.project_id).first()
        if project:
            work_order.project_name = project.name
    
    if work_order.supplier_id:
        supplier = db.query(Supplier).filter(Supplier.id == work_order.supplier_id).first()
        if supplier:
            work_order.supplier_name = supplier.name
    
    return work_order

