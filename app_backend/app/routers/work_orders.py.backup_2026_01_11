# ============ EQUIPMENT ATTACHMENT ENDPOINT ============

@router.post("/{work_order_id}/attach-equipment", response_model=AttachEquipmentResponse)
def attach_equipment_to_work_order(
    work_order_id: int,
    request: AttachEquipmentRequest,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_active_user)
):
    """
    Attach equipment to a work order via QR scan or license plate.
    
    This is the main endpoint for equipment intake/scanning.
    
    Flow:
    1. Find work order
    2. Find equipment by QR or license plate
    3. Validate equipment type match (optional)
    4. Update work order with equipment_id
    5. Create equipment_scan record
    6. Return equipment balances for next steps
    """
    
    # Step A: Find the work order
    work_order = db.query(WorkOrder).filter(WorkOrder.id == work_order_id).first()
    if not work_order:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="הזמנת עבודה לא נמצאה"
        )
    
    # Check work order status
    if work_order.status in ['cancelled', 'CANCELLED', 'completed', 'COMPLETED']:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="לא ניתן לקלוט כלי להזמנה שבוטלה או הסתיימה"
        )
    
    # Check if equipment already attached
    if work_order.equipment_id:
        # Get current equipment info
        existing_equipment = db.query(Equipment).filter(
            Equipment.id == work_order.equipment_id
        ).first()
        raise HTTPException(
            status_code=status.HTTP_409_CONFLICT,
            detail=f"להזמנה כבר מחובר כלי: {existing_equipment.license_plate if existing_equipment else work_order.equipment_id}"
        )
    
    # Step B: Find the equipment
    equipment = None
    scan_type_upper = request.scan_type.upper()
    
    if scan_type_upper == "QR":
        equipment = db.query(Equipment).filter(
            Equipment.qr_code == request.scan_value
        ).first()
    elif scan_type_upper == "LICENSE":
        equipment = db.query(Equipment).filter(
            Equipment.license_plate == request.scan_value
        ).first()
    else:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail=f"סוג סריקה לא נתמך: {request.scan_type}. השתמש ב-QR או LICENSE"
        )
    
    if not equipment:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail=f"כלי לא נמצא: {request.scan_value}"
        )
    
    # Step C: Check equipment type match (if work order has equipment_type)
    warning = None
    if work_order.equipment_type and equipment.equipment_type:
        if work_order.equipment_type.lower() != equipment.equipment_type.lower():
            if not request.force_attach:
                raise HTTPException(
                    status_code=status.HTTP_409_CONFLICT,
                    detail={
                        "error": "equipment_type_mismatch",
                        "message": f"סוג הכלי לא תואם. צפוי: {work_order.equipment_type}, נמצא: {equipment.equipment_type}",
                        "expected_type": work_order.equipment_type,
                        "actual_type": equipment.equipment_type,
                        "requires_force": True
                    }
                )
            else:
                warning = f"חריגה: סוג כלי לא תואם ({equipment.equipment_type} במקום {work_order.equipment_type}). סיבה: {request.force_reason or 'לא צוינה'}"
    
    # Step D: Update the work order with equipment_id
    work_order.equipment_id = equipment.id
    work_order.response_received_at = work_order.response_received_at or datetime.utcnow()
    work_order.updated_at = datetime.utcnow()
    
    # If equipment is being attached, move to in_progress if currently accepted
    if work_order.status in ['accepted', 'ACCEPTED']:
        work_order.status = 'in_progress'
    
    # Step E: Create equipment_scan record
    scan_record = EquipmentScan(
        equipment_id=equipment.id,
        scanned_by=current_user.id,
        location_id=request.location_id,
        scan_type=scan_type_upper,
        scan_value=request.scan_value,
        scan_timestamp=datetime.utcnow(),
        latitude=request.latitude,
        longitude=request.longitude,
        device_info=request.device_info,
        purpose="WORK_ORDER_ATTACH",
        status="SUCCESS",
        notes=request.notes or (f"Force attach: {request.force_reason}" if request.force_attach else None),
        is_active=True,
        work_order_id=work_order_id
    )
    db.add(scan_record)
    
    # Commit changes
    db.commit()
    db.refresh(work_order)
    
    # Step F: Calculate equipment balances from view
    allocated_hours = 0.0
    used_hours = 0.0
    remaining_hours = 0.0
    
    try:
        result = db.execute(text("""
            SELECT allocated_hours, used_hours, remaining_hours
            FROM dbo.vw_project_equipment_balances
            WHERE project_id = :project_id AND equipment_id = :equipment_id
        """), {
            "project_id": work_order.project_id,
            "equipment_id": equipment.id
        }).fetchone()
        
        if result:
            allocated_hours = float(result[0] or 0)
            used_hours = float(result[1] or 0)
            remaining_hours = float(result[2] or 0)
    except Exception as e:
        # View might not exist or have different structure
        # Fall back to estimated_hours from work order
        allocated_hours = float(work_order.estimated_hours or 0)
        remaining_hours = allocated_hours
    
    return AttachEquipmentResponse(
        success=True,
        work_order_id=work_order.id,
        project_id=work_order.project_id,
        equipment_id=equipment.id,
        license_plate=equipment.license_plate,
        equipment_type=equipment.equipment_type,
        equipment_name=equipment.name,
        allocated_hours=allocated_hours,
        used_hours=used_hours,
        remaining_hours=remaining_hours,
        next_action="OPEN_WORKLOG",
        warning=warning
    )


