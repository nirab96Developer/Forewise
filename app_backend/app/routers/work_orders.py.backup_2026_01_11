@router.post("/{work_order_id}/resend-to-supplier")
def resend_to_supplier(
    work_order_id: int,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_active_user)
):
    """Resend work order to supplier - Order Coordinator action"""
    from app.models.work_order_coordination_log import WorkOrderCoordinationLog
    
    work_order = db.query(WorkOrder).filter(WorkOrder.id == work_order_id).first()
    if not work_order:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="הזמנה לא נמצאה"
        )
    
    if not work_order.supplier_id:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="אין ספק מוגדר להזמנה זו"
        )
    
    supplier = db.query(Supplier).filter(Supplier.id == work_order.supplier_id).first()
    if not supplier or not supplier.email:
        raise HTTPException(
            status_code=status.HTTP_400_BAD_REQUEST,
            detail="לא נמצא מייל לספק"
        )
    
    # Generate new token and extend expiry
    work_order.portal_token = secrets.token_urlsafe(32)
    work_order.portal_token_expires = datetime.utcnow() + timedelta(hours=3)
    work_order.status = "SENT"
    work_order.updated_at = datetime.utcnow()
    
    # Update send count (if field exists)
    if hasattr(work_order, 'send_count'):
        work_order.send_count = (work_order.send_count or 0) + 1
    if hasattr(work_order, 'last_sent_at'):
        work_order.last_sent_at = datetime.utcnow()
    
    # Log the resend action
    log_entry = WorkOrderCoordinationLog(
        work_order_id=work_order_id,
        action_type="RESEND",
        note=f"נשלח מחדש לספק {supplier.name}",
        created_by_user_id=current_user.id,
        created_at=datetime.utcnow()
    )
    db.add(log_entry)
    
    db.commit()
    
    # Get project info
    project = db.query(Project).filter(Project.id == work_order.project_id).first() if work_order.project_id else None
    
    # Send email
    frontend_url = getattr(settings, 'FRONTEND_URL', 'http://localhost:5173')
    portal_url = f"{frontend_url}/#/supplier-portal/{work_order.portal_token}"
    
    email_body = f"""
שלום {supplier.name},

תזכורת: התקבלה הזמנת עבודה שממתינה לתגובתך:

מספר הזמנה: {work_order.order_number}
פרויקט: {project.name if project else 'לא מוגדר'}
סוג כלי: {work_order.equipment_type or 'לא מוגדר'}
תאריך התחלה: {work_order.work_start_date or 'לא מוגדר'}
שעות משוערות: {work_order.estimated_hours or 'לא מוגדר'}

לאישור או דחיית ההזמנה, לחץ על הקישור הבא:
{portal_url}

הקישור יפוג בעוד 3 שעות.

בברכה,
מערכת ניהול יערות - קק"ל
    """
    
    try:
        send_email(
            to=supplier.email,
            subject=f"🔄 תזכורת: הזמנת עבודה #{work_order.order_number} ממתינה לתגובה",
            body=email_body
        )
    except Exception as e:
        print(f"Failed to send email to supplier: {e}")
    
    return {
        "success": True,
        "message": "ההזמנה נשלחה מחדש לספק",
        "order_number": work_order.order_number
    }


@router.post("/{work_order_id}/move-next-supplier")
