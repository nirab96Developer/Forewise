@router.post("/", response_model=WorkOrderResponse)
def create_work_order(
    work_order: WorkOrderCreate,
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_active_user)
):
    """Create a new work order."""
    # Verify project exists if provided
    project = None
    if work_order.project_id:
        project = db.query(Project).filter(Project.id == work_order.project_id).first()
        if not project:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail="Project not found"
            )
    
    # Verify supplier exists if provided
    if work_order.supplier_id:
        supplier = db.query(Supplier).filter(Supplier.id == work_order.supplier_id).first()
        if not supplier:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail="Supplier not found"
            )
    
    # Auto-generate order_number
    max_order = db.query(WorkOrder).order_by(WorkOrder.order_number.desc()).first()
    next_order_number = (max_order.order_number + 1) if max_order and max_order.order_number else 1
    
    db_work_order = WorkOrder(
        **work_order.model_dump(exclude_unset=True),
        order_number=next_order_number,
        created_by_id=current_user.id,
        created_at=datetime.utcnow(),
        updated_at=datetime.utcnow()
    )
    
    # Generate portal token and set expiry (3 hours)
    db_work_order.portal_token = secrets.token_urlsafe(32)
    db_work_order.portal_token_expires = datetime.utcnow() + timedelta(hours=3)
    # Use valid status codes from work_order_statuses table
    db_work_order.status = "SENT" if work_order.supplier_id else "PENDING"
    
    db.add(db_work_order)
    db.commit()
    db.refresh(db_work_order)
    
    # Send email to supplier if assigned
    supplier = None
    if work_order.supplier_id:
        supplier = db.query(Supplier).filter(Supplier.id == work_order.supplier_id).first()
        if supplier and supplier.email:
            # Build portal URL
            frontend_url = getattr(settings, 'FRONTEND_URL', 'http://localhost:5173')
            portal_url = f"{frontend_url}/#/supplier-portal/{db_work_order.portal_token}"
            
            # Send email to supplier
            email_body = f"""
שלום {supplier.name},

התקבלה הזמנת עבודה חדשה:

פרויקט: {project.name if project else 'לא מוגדר'}
סוג כלי: {work_order.equipment_type or 'לא מוגדר'}
תאריך התחלה: {work_order.work_start_date or 'לא מוגדר'}
שעות משוערות: {work_order.estimated_hours or 'לא מוגדר'}

לאישור או דחיית ההזמנה, לחץ על הקישור הבא:
{portal_url}

הקישור יפוג בעוד 3 שעות.

בברכה,
מערכת ניהול יערות - קק"ל
            """
            
            try:
                send_email(
                    to=supplier.email,
                    subject=f"הזמנת עבודה חדשה #{db_work_order.order_number}",
                    body=email_body
                )
            except Exception as e:
                print(f"Failed to send email to supplier: {e}")
    
    # Add project and supplier names to response
    if project:
        db_work_order.project_name = project.name
    if supplier:
        db_work_order.supplier_name = supplier.name
    
    return db_work_order

@router.patch("/{work_order_id}", response_model=WorkOrderResponse)
