# ============ ATTACH EQUIPMENT SCHEMAS ============

class AttachEquipmentRequest(BaseModel):
    """Request body for attaching equipment to a work order"""
    scan_type: str = Field(..., description="QR or LICENSE")
    scan_value: str = Field(..., description="The QR code or license plate value")
    location_id: Optional[int] = None
    latitude: Optional[float] = None
    longitude: Optional[float] = None
    device_info: Optional[str] = None
    notes: Optional[str] = None
    force_attach: bool = Field(default=False, description="Force attach even if equipment type mismatch")
    force_reason: Optional[str] = Field(None, description="Reason for force attach")


class AttachEquipmentResponse(BaseModel):
    """Response after attaching equipment to a work order"""
    success: bool
    work_order_id: int
    project_id: Optional[int]
    equipment_id: int
    license_plate: Optional[str]
    equipment_type: Optional[str]
    equipment_name: Optional[str]
    allocated_hours: float
    used_hours: float
    remaining_hours: float
    next_action: str = "OPEN_WORKLOG"
    warning: Optional[str] = None

router = APIRouter(prefix="/work-orders", tags=["Work Orders"])

@router.get("/", response_model=PaginatedResponse[WorkOrderResponse])
def get_work_orders(
    pagination: PaginationParams = Depends(),
    filters: WorkOrderFilters = Depends(),
    db: Session = Depends(get_db),
    current_user: User = Depends(get_current_active_user)
):
    """Get all work orders with pagination and filtering."""
    query = db.query(WorkOrder)
    
    # Apply filters
    if filters.status:
        query = query.filter(WorkOrder.status == filters.status)
    if filters.priority:
        query = query.filter(WorkOrder.priority == filters.priority)
    if filters.project_id:
        query = query.filter(WorkOrder.project_id == filters.project_id)
    if filters.supplier_id:
        query = query.filter(WorkOrder.supplier_id == filters.supplier_id)
    if filters.equipment_type:
        query = query.filter(WorkOrder.equipment_type.ilike(f"%{filters.equipment_type}%"))
    if filters.date_from:
        query = query.filter(WorkOrder.work_start_date >= filters.date_from)
    if filters.date_to:
        query = query.filter(WorkOrder.work_end_date <= filters.date_to)
    
    # Get total count
    total = query.count()
    
    # Apply pagination with ORDER BY (required for SQL Server)
    offset = (pagination.page - 1) * pagination.page_size
    work_orders = query.order_by(WorkOrder.id).offset(offset).limit(pagination.page_size).all()
    
    # Add project and supplier names
    for work_order in work_orders:
        if work_order.project_id:
            project = db.query(Project).filter(Project.id == work_order.project_id).first()
            if project:
                work_order.project_name = project.name
        
        if work_order.supplier_id:
            supplier = db.query(Supplier).filter(Supplier.id == work_order.supplier_id).first()
            if supplier:
                work_order.supplier_name = supplier.name
    
    return PaginatedResponse(
        items=work_orders,
        total=total,
        page=pagination.page,
        page_size=pagination.page_size,
        pages=(total + pagination.page_size - 1) // pagination.page_size,
        has_next=pagination.page < (total + pagination.page_size - 1) // pagination.page_size,
        has_prev=pagination.page > 1
    )

