"""
Areas Router
"""
from fastapi import APIRouter, Depends, HTTPException, status
from sqlalchemy.orm import Session
from typing import Annotated

from app.core.database import get_db
from app.core.dependencies import get_current_active_user, require_permission
from app.models.user import User
from app.schemas.area import AreaCreate, AreaUpdate, AreaResponse, AreaListResponse, AreaSearch
from app.services.area_service import area_service

router = APIRouter(prefix="/areas", tags=["areas"])


@router.get("", response_model=AreaListResponse)
def list_areas(
    filters: Annotated[AreaSearch, Depends()],
    db: Annotated[Session, Depends(get_db)],
    current_user: Annotated[User, Depends(get_current_active_user)],
):
    require_permission(current_user, "areas.list")
    areas, total = area_service.list_with_filters(db, filters)
    total_pages = (total + filters.page_size - 1) // filters.page_size
    return AreaListResponse(items=areas, total=total, page=filters.page, page_size=filters.page_size, total_pages=total_pages)


@router.get("/{area_id}", response_model=AreaResponse)
def get_area(
    area_id: int,
    db: Annotated[Session, Depends(get_db)],
    current_user: Annotated[User, Depends(get_current_active_user)],
):
    require_permission(current_user, "areas.read")
    area = area_service.get_by_id(db, area_id)
    if not area:
        raise HTTPException(status_code=404, detail="Area not found")
    return area


@router.get("/by-code/{code}", response_model=AreaResponse)
def get_area_by_code(
    code: str,
    db: Annotated[Session, Depends(get_db)],
    current_user: Annotated[User, Depends(get_current_active_user)],
):
    require_permission(current_user, "areas.read")
    area = area_service.get_by_code(db, code)
    if not area:
        raise HTTPException(status_code=404, detail="Area not found")
    return area


@router.post("", response_model=AreaResponse, status_code=status.HTTP_201_CREATED)
def create_area(
    area_data: AreaCreate,
    db: Annotated[Session, Depends(get_db)],
    current_user: Annotated[User, Depends(get_current_active_user)],
):
    require_permission(current_user, "areas.create")
    return area_service.create_area(db, area_data)


@router.put("/{area_id}", response_model=AreaResponse)
def update_area(
    area_id: int,
    area_data: AreaUpdate,
    db: Annotated[Session, Depends(get_db)],
    current_user: Annotated[User, Depends(get_current_active_user)],
):
    require_permission(current_user, "areas.update")
    return area_service.update_area(db, area_id, area_data)


@router.delete("/{area_id}", status_code=status.HTTP_204_NO_CONTENT)
def delete_area(
    area_id: int,
    db: Annotated[Session, Depends(get_db)],
    current_user: Annotated[User, Depends(get_current_active_user)],
):
    require_permission(current_user, "areas.delete")
    area_service.soft_delete(db, area_id)
    return None
