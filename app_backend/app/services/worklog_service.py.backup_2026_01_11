    def get_worklog_statistics(
        self, db: Session, 
        user_id: Optional[int] = None, 
        project_id: Optional[int] = None,
        date_from: Optional[date] = None,
        date_to: Optional[date] = None,
    ) -> Dict[str, Any]:
        """Get worklog statistics."""
        query = db.query(Worklog)
        
        if user_id:
            query = query.filter(Worklog.user_id == user_id)
        if project_id:
            query = query.filter(Worklog.project_id == project_id)
        if date_from:
            query = query.filter(Worklog.report_date >= date_from)
        if date_to:
            query = query.filter(Worklog.report_date <= date_to)

        total_worklogs = query.count()
        
        # Count by status
        status_counts = {}
        for status in ["draft", "pending", "submitted", "approved", "rejected", "invoiced"]:
            count = query.filter(Worklog.status == status).count()
            status_counts[f"{status}_count"] = count

        # Hours statistics
        total_hours = query.with_entities(func.sum(Worklog.total_hours)).scalar() or Decimal("0")
        avg_hours = query.with_entities(func.avg(Worklog.total_hours)).scalar() or Decimal("0")

        # Standard vs non-standard
        standard_count = query.filter(Worklog.is_standard == True).count()
        non_standard_count = query.filter(Worklog.is_standard == False).count()

        return {
            "total_worklogs": total_worklogs,
            **status_counts,
            "total_hours": float(total_hours),
            "average_hours": float(avg_hours),
            "standard_count": standard_count,
            "non_standard_count": non_standard_count,
        }

    def generate_report_number_formatted(self, report_date: date, report_number: int) -> str:
        """Generate formatted report number: WR-YYYY-NNNNNN"""
        return f"WR-{report_date.year}-{report_number:06d}"

    def check_equipment_scanned(self, db: Session, worklog_id: int) -> bool:
        """Check if equipment was scanned for this worklog."""
        worklog = self.get_worklog(db, worklog_id)
        return worklog.equipment_scanned if worklog else False
