# app/services/payment_service.py
"""Payment processing and management service."""
from datetime import date, datetime, timedelta
from decimal import Decimal
from typing import Any, Dict, List, Optional

from sqlalchemy import and_, func, or_
from sqlalchemy.orm import Session, joinedload

from app.models.budget import Budget
# from app.models.invoice import Invoice
# from app.models.invoice_payment import InvoicePayment
from app.models.supplier import Supplier
from app.schemas.payment import PaymentCreate, PaymentUpdate


class PaymentService:
    """Service for payment operations."""

    def get_payment(self, db: Session, payment_id: int) -> Optional[InvoicePayment]:
        """Get payment by ID."""
        return (
            db.query(InvoicePayment)
            .options(
                joinedload(InvoicePayment.invoice),
                joinedload(InvoicePayment.approved_by),
            )
            .filter(
                and_(InvoicePayment.id == payment_id, InvoicePayment.is_active == True)
            )
            .first()
        )

    def get_payments(
        self,
        db: Session,
        skip: int = 0,
        limit: int = 100,
        invoice_id: Optional[int] = None,
        supplier_id: Optional[int] = None,
        status: Optional[str] = None,
        payment_method: Optional[str] = None,
        start_date: Optional[date] = None,
        end_date: Optional[date] = None,
    ) -> List[InvoicePayment]:
        """Get list of payments with filters."""
        query = db.query(InvoicePayment).filter(InvoicePayment.is_active == True)

        if invoice_id:
            query = query.filter(InvoicePayment.invoice_id == invoice_id)

        if supplier_id:
            query = query.join(Invoice).filter(Invoice.supplier_id == supplier_id)

        if status:
            query = query.filter(InvoicePayment.status == status)

        if payment_method:
            query = query.filter(InvoicePayment.payment_method == payment_method)

        if start_date:
            query = query.filter(InvoicePayment.payment_date >= start_date)

        if end_date:
            query = query.filter(InvoicePayment.payment_date <= end_date)

        return (
            query.order_by(InvoicePayment.payment_date.desc())
            .offset(skip)
            .limit(limit)
            .all()
        )

    def create_payment(
        self, db: Session, payment: PaymentCreate, created_by_id: int
    ) -> InvoicePayment:
        """Create new payment."""
        # Get invoice
        invoice = db.query(Invoice).filter(Invoice.id == payment.invoice_id).first()

        if not invoice:
            raise ValueError("Invoice not found")

        # Check invoice status
        if invoice.status == "cancelled":
            raise ValueError("Cannot pay cancelled invoice")

        # Calculate remaining amount
        paid_amount = db.query(func.sum(InvoicePayment.amount)).filter(
            and_(
                InvoicePayment.invoice_id == invoice.id,
                InvoicePayment.status != "cancelled",
                InvoicePayment.is_active == True,
            )
        ).scalar() or Decimal("0")

        remaining = invoice.total_amount - paid_amount

        if payment.amount > remaining:
            raise ValueError(f"Payment amount exceeds remaining balance: {remaining}")

        # Create payment
        db_payment = InvoicePayment(
            invoice_id=payment.invoice_id,
            amount=payment.amount,
            payment_method=payment.payment_method,
            payment_date=payment.payment_date or date.today(),
            reference_number=payment.reference_number,
            bank_account=payment.bank_account,
            notes=payment.notes,
            status="pending",
            created_by_id=created_by_id,
            created_at=datetime.utcnow(),
        )

        db.add(db_payment)
        db.commit()
        db.refresh(db_payment)

        # Update invoice status if fully paid
        self._update_invoice_payment_status(db, invoice.id)

        return db_payment

    def update_payment(
        self, db: Session, payment_id: int, payment: PaymentUpdate
    ) -> Optional[InvoicePayment]:
        """Update payment."""
        db_payment = self.get_payment(db, payment_id)
        if not db_payment:
            return None

        # Don't allow updating processed payments
        if db_payment.status in ["processed", "cleared"]:
            raise ValueError("Cannot update processed payment")

        update_data = payment.dict(exclude_unset=True)
        for field, value in update_data.items():
            setattr(db_payment, field, value)

        db_payment.updated_at = datetime.utcnow()
        db.commit()
        db.refresh(db_payment)

        # Update invoice status
        self._update_invoice_payment_status(db, db_payment.invoice_id)

        return db_payment

    def approve_payment(
        self,
        db: Session,
        payment_id: int,
        approved_by_id: int,
        approval_notes: Optional[str] = None,
    ) -> Optional[InvoicePayment]:
        """Approve payment for processing."""
        db_payment = self.get_payment(db, payment_id)
        if not db_payment:
            return None

        if db_payment.status != "pending":
            raise ValueError("Payment not in pending status")

        db_payment.status = "approved"
        db_payment.approved_by_id = approved_by_id
        db_payment.approved_at = datetime.utcnow()
        db_payment.approval_notes = approval_notes
        db_payment.updated_at = datetime.utcnow()

        db.commit()
        db.refresh(db_payment)

        # Send for processing
        self._process_payment(db, db_payment)

        return db_payment

    def cancel_payment(self, db: Session, payment_id: int, reason: str) -> bool:
        """Cancel payment."""
        db_payment = self.get_payment(db, payment_id)
        if not db_payment:
            return False

        if db_payment.status in ["processed", "cleared"]:
            raise ValueError("Cannot cancel processed payment")

        db_payment.status = "cancelled"
        db_payment.cancellation_reason = reason
        db_payment.cancelled_at = datetime.utcnow()
        db_payment.updated_at = datetime.utcnow()

        db.commit()

        # Update invoice status
        self._update_invoice_payment_status(db, db_payment.invoice_id)

        return True

    def process_payment_batch(
        self,
        db: Session,
        payment_ids: List[int],
        batch_reference: str,
        processed_by_id: int,
    ) -> Dict[str, Any]:
        """Process multiple payments as batch."""
        results = {
            "total": len(payment_ids),
            "successful": 0,
            "failed": 0,
            "errors": [],
        }

        for payment_id in payment_ids:
            try:
                payment = self.get_payment(db, payment_id)
                if not payment:
                    results["errors"].append(
                        {"payment_id": payment_id, "error": "Payment not found"}
                    )
                    results["failed"] += 1
                    continue

                if payment.status != "approved":
                    results["errors"].append(
                        {"payment_id": payment_id, "error": "Payment not approved"}
                    )
                    results["failed"] += 1
                    continue

                # Process payment
                payment.status = "processed"
                payment.batch_reference = batch_reference
                payment.processed_by_id = processed_by_id
                payment.processed_at = datetime.utcnow()
                payment.updated_at = datetime.utcnow()

                results["successful"] += 1

            except Exception as e:
                results["errors"].append({"payment_id": payment_id, "error": str(e)})
                results["failed"] += 1

        db.commit()
        return results

    def reconcile_payment(
        self,
        db: Session,
        payment_id: int,
        bank_statement_ref: str,
        actual_date: date,
        actual_amount: Optional[Decimal] = None,
    ) -> Optional[InvoicePayment]:
        """Reconcile payment with bank statement."""
        db_payment = self.get_payment(db, payment_id)
        if not db_payment:
            return None

        if db_payment.status != "processed":
            raise ValueError("Payment must be processed before reconciliation")

        db_payment.status = "cleared"
        db_payment.bank_statement_ref = bank_statement_ref
        db_payment.cleared_date = actual_date

        # Check for amount discrepancy
        if actual_amount and actual_amount != db_payment.amount:
            db_payment.reconciliation_notes = (
                f"Amount discrepancy: Expected {db_payment.amount}, "
                f"Actual {actual_amount}"
            )

        db_payment.reconciled_at = datetime.utcnow()
        db_payment.updated_at = datetime.utcnow()

        db.commit()
        db.refresh(db_payment)
        return db_payment

    def get_payment_summary(
        self,
        db: Session,
        start_date: date,
        end_date: date,
        supplier_id: Optional[int] = None,
    ) -> Dict[str, Any]:
        """Get payment summary statistics."""
        query = (
            db.query(InvoicePayment)
            .join(Invoice)
            .filter(
                and_(
                    InvoicePayment.payment_date >= start_date,
                    InvoicePayment.payment_date <= end_date,
                    InvoicePayment.is_active == True,
                )
            )
        )

        if supplier_id:
            query = query.filter(Invoice.supplier_id == supplier_id)

        payments = query.all()

        # Calculate totals by status
        status_totals = {}
        method_totals = {}
        total_amount = Decimal("0")

        for payment in payments:
            # By status
            if payment.status not in status_totals:
                status_totals[payment.status] = Decimal("0")
            status_totals[payment.status] += payment.amount

            # By method
            if payment.payment_method not in method_totals:
                method_totals[payment.payment_method] = Decimal("0")
            method_totals[payment.payment_method] += payment.amount

            if payment.status != "cancelled":
                total_amount += payment.amount

        # Average processing time
        processing_times = []
        for payment in payments:
            if payment.processed_at and payment.created_at:
                time_diff = (
                    payment.processed_at - payment.created_at
                ).total_seconds() / 3600
                processing_times.append(time_diff)

        avg_processing_time = (
            sum(processing_times) / len(processing_times) if processing_times else 0
        )

        return {
            "period": {"start": start_date.isoformat(), "end": end_date.isoformat()},
            "total_payments": len(payments),
            "total_amount": float(total_amount),
            "by_status": {k: float(v) for k, v in status_totals.items()},
            "by_method": {k: float(v) for k, v in method_totals.items()},
            "avg_processing_hours": round(avg_processing_time, 2),
        }

    def get_pending_payments(
        self, db: Session, days_old: Optional[int] = None
    ) -> List[Dict[str, Any]]:
        """Get pending payments requiring action."""
        query = (
            db.query(InvoicePayment, Invoice, Supplier)
            .join(Invoice)
            .join(Supplier)
            .filter(
                and_(
                    InvoicePayment.status.in_(["pending", "approved"]),
                    InvoicePayment.is_active == True,
                )
            )
        )

        if days_old:
            cutoff = datetime.utcnow() - timedelta(days=days_old)
            query = query.filter(InvoicePayment.created_at <= cutoff)

        results = query.all()

        pending = []
        for payment, invoice, supplier in results:
            days_pending = (datetime.utcnow() - payment.created_at).days

            pending.append(
                {
                    "payment_id": payment.id,
                    "invoice_id": invoice.id,
                    "invoice_number": invoice.invoice_number,
                    "supplier_name": supplier.name,
                    "amount": float(payment.amount),
                    "payment_date": payment.payment_date.isoformat(),
                    "status": payment.status,
                    "days_pending": days_pending,
                    "requires_approval": payment.status == "pending",
                }
            )

        # Sort by days pending
        pending.sort(key=lambda x: x["days_pending"], reverse=True)

        return pending

    def _update_invoice_payment_status(self, db: Session, invoice_id: int):
        """Update invoice payment status based on payments."""
        invoice = db.query(Invoice).filter(Invoice.id == invoice_id).first()
        if not invoice:
            return

        # Calculate total paid
        total_paid = db.query(func.sum(InvoicePayment.amount)).filter(
            and_(
                InvoicePayment.invoice_id == invoice_id,
                InvoicePayment.status.in_(["approved", "processed", "cleared"]),
                InvoicePayment.is_active == True,
            )
        ).scalar() or Decimal("0")

        invoice.paid_amount = total_paid

        # Update status
        if total_paid >= invoice.total_amount:
            invoice.status = "paid"
            invoice.paid_at = datetime.utcnow()
        elif total_paid > 0:
            invoice.status = "partial"
        else:
            if invoice.status == "paid" or invoice.status == "partial":
                invoice.status = "sent"

        db.commit()

    def _process_payment(self, db: Session, payment: InvoicePayment):
        """Process approved payment."""
        # Update budget if linked
        invoice = payment.invoice
        if invoice and invoice.project_id:
            from app.models.project import Project

            project = db.query(Project).filter(Project.id == invoice.project_id).first()

            if project and project.budget_id:
                budget = db.query(Budget).filter(Budget.id == project.budget_id).first()

                if budget:
                    budget.spent_amount += payment.amount
                    budget.available_amount = (
                        budget.total_amount
                        - budget.allocated_amount
                        - budget.spent_amount
                    )

        # Send notification to supplier
        from app.services.notification_service import NotificationService

        notification_service = NotificationService()

        if invoice and invoice.supplier:
            # Find supplier's user account
            from app.models.user import User

            supplier_user = (
                db.query(User).filter(User.email == invoice.supplier.email).first()
            )

            if supplier_user:
                notification_service.create_notification(
                    db=db,
                    user_id=supplier_user.id,
                    title="Payment Processed",
                    message=f"Payment of {payment.amount} for invoice {invoice.invoice_number} has been processed",
                    notification_type="success",
                    channels=["email", "in_app"],
                    metadata={"invoice_id": invoice.id, "payment_id": payment.id},
                )
