# app/services/invoice_service.py
"""Invoice management service."""
from datetime import date, datetime, timedelta
from decimal import Decimal
from typing import List, Optional, Dict, Any

from sqlalchemy import and_, or_, func, desc
from sqlalchemy.orm import Session, joinedload

# from app.models.invoice import Invoice
# from app.models.invoice_item import InvoiceItem
# from app.models.invoice_payment import InvoicePayment
from app.models.worklog import Worklog
from app.models.supplier import Supplier
from app.models.project import Project
from app.schemas.invoice import (InvoiceCreate, InvoiceUpdate, InvoiceItemCreate,
                                PaymentCreate, InvoiceGenerationRequest)


class InvoiceService:
    """Service for invoice operations."""

    def get_invoice(self, db: Session, invoice_id: int) -> Optional[Invoice]:
        """Get invoice by ID with relationships."""
        return (
            db.query(Invoice)
            .options(
                joinedload(Invoice.supplier),
                joinedload(Invoice.project),
                joinedload(Invoice.items),
                joinedload(Invoice.payments)
            )
            .filter(Invoice.id == invoice_id)
            .first()
        )

    def get_invoices(
        self,
        db: Session,
        skip: int = 0,
        limit: int = 100,
        supplier_id: Optional[int] = None,
        project_id: Optional[int] = None,
        status: Optional[str] = None,
        is_overdue: Optional[bool] = None,
    ) -> List[Invoice]:
        """Get list of invoices with filters."""
        query = db.query(Invoice)

        if supplier_id:
            query = query.filter(Invoice.supplier_id == supplier_id)
        if project_id:
            query = query.filter(Invoice.project_id == project_id)
        if status:
            query = query.filter(Invoice.status == status)
        if is_overdue is not None:
            if is_overdue:
                query = query.filter(
                    and_(
                        Invoice.due_date < date.today(),
                        Invoice.status.in_(["pending", "approved", "sent"])
                    )
                )
            else:
                query = query.filter(
                    or_(
                        Invoice.due_date >= date.today(),
                        Invoice.status.in_(["paid", "cancelled"])
                    )
                )

        return query.offset(skip).limit(limit).all()

    def generate_invoice(
        self, db: Session, request: InvoiceGenerationRequest, created_by_id: int
    ) -> Invoice:
        """Generate invoice from worklogs."""
        # Validate supplier
        supplier = db.query(Supplier).filter(Supplier.id == request.supplier_id).first()
        if not supplier:
            raise ValueError("Supplier not found")

        # Get worklogs
        worklogs = db.query(Worklog).filter(
            and_(
                Worklog.id.in_(request.include_worklogs),
                Worklog.status == "approved"
            )
        ).all()

        if not worklogs:
            raise ValueError("No approved worklogs found")

        # Calculate totals
        subtotal = sum(w.total_hours * w.work_order.hourly_rate for w in worklogs if w.work_order)
        tax_amount = subtotal * request.tax_rate
        discount_amount = subtotal * request.discount_percentage
        total_amount = subtotal + tax_amount - discount_amount

        # Generate invoice number
        invoice_number = self._generate_invoice_number(db)

        # Create invoice
        db_invoice = Invoice(
            invoice_number=invoice_number,
            supplier_id=request.supplier_id,
            project_id=request.project_id,
            period_start=request.period_start,
            period_end=request.period_end,
            due_date=request.due_date or (request.period_end + timedelta(days=30)),
            currency=request.currency or "ILS",
            notes=request.notes,
            subtotal=subtotal,
            tax_amount=tax_amount,
            discount_amount=discount_amount,
            total_amount=total_amount,
            status="draft",
            created_by_id=created_by_id,
            created_at=datetime.utcnow()
        )

        db.add(db_invoice)
        db.flush()  # Get the ID

        # Create invoice items from worklogs
        for worklog in worklogs:
            if worklog.work_order:
                item = InvoiceItem(
                    invoice_id=db_invoice.id,
                    worklog_id=worklog.id,
                    description=f"Work hours - {worklog.activity_type}",
                    quantity=int(worklog.total_hours),
                    unit_price=worklog.work_order.hourly_rate,
                    unit="hours",
                    category="labor"
                )
                db.add(item)

        db.commit()
        db.refresh(db_invoice)
        return db_invoice

    def _generate_invoice_number(self, db: Session) -> str:
        """Generate unique invoice number."""
        # Get the last invoice number
        last_invoice = db.query(Invoice).order_by(desc(Invoice.id)).first()
        
        if last_invoice and last_invoice.invoice_number:
            # Extract number from last invoice
            try:
                last_number = int(last_invoice.invoice_number.split('-')[-1])
                new_number = last_number + 1
            except (ValueError, IndexError):
                new_number = 1
        else:
            new_number = 1
        
        return f"INV-{new_number:06d}"

    def create_invoice(
        self, db: Session, invoice: InvoiceCreate, created_by_id: int
    ) -> Invoice:
        """Create new invoice."""
        # Validate supplier
        supplier = db.query(Supplier).filter(Supplier.id == invoice.supplier_id).first()
        if not supplier:
            raise ValueError("Supplier not found")

        # Generate invoice number
        invoice_number = self._generate_invoice_number(db)

        # Create invoice
        db_invoice = Invoice(
            **invoice.dict(exclude={"worklog_ids", "tax_rate", "discount_percentage", "discount_amount"}),
            invoice_number=invoice_number,
            subtotal=Decimal("0"),
            tax_amount=Decimal("0"),
            discount_amount=Decimal("0"),
            total_amount=Decimal("0"),
            status="draft",
            created_by_id=created_by_id,
            created_at=datetime.utcnow()
        )

        db.add(db_invoice)
        db.flush()  # Get the ID

        # Create items from worklogs
        if invoice.worklog_ids:
            worklogs = db.query(Worklog).filter(
                and_(
                    Worklog.id.in_(invoice.worklog_ids),
                    Worklog.status == "approved"
                )
            ).all()

            subtotal = Decimal("0")
            for worklog in worklogs:
                if worklog.work_order:
                    item_amount = worklog.total_hours * worklog.work_order.hourly_rate
                    subtotal += item_amount

                    item = InvoiceItem(
                        invoice_id=db_invoice.id,
                        worklog_id=worklog.id,
                        description=f"Work hours - {worklog.activity_type}",
                        quantity=int(worklog.total_hours),
                        unit_price=worklog.work_order.hourly_rate,
                        unit="hours",
                        category="labor"
                    )
                    db.add(item)

            # Calculate totals
            tax_amount = subtotal * invoice.tax_rate
            discount_amount = subtotal * invoice.discount_percentage
            total_amount = subtotal + tax_amount - discount_amount

            db_invoice.subtotal = subtotal
            db_invoice.tax_amount = tax_amount
            db_invoice.discount_amount = discount_amount
            db_invoice.total_amount = total_amount

        db.commit()
        db.refresh(db_invoice)
        return db_invoice

    def update_invoice(
        self, db: Session, invoice_id: int, invoice: InvoiceUpdate
    ) -> Optional[Invoice]:
        """Update invoice."""
        db_invoice = self.get_invoice(db, invoice_id)
        if not db_invoice:
            return None

        # Don't allow updating paid or cancelled invoices
        if db_invoice.status in ["paid", "cancelled"]:
            raise ValueError("Cannot update paid or cancelled invoice")

        update_data = invoice.dict(exclude_unset=True)
        for field, value in update_data.items():
            setattr(db_invoice, field, value)

        db_invoice.updated_at = datetime.utcnow()
        db.commit()
        db.refresh(db_invoice)
        return db_invoice

    def approve_invoice(
        self, db: Session, invoice_id: int, approver_id: int, notes: Optional[str] = None
    ) -> Optional[Invoice]:
        """Approve invoice."""
        invoice = self.get_invoice(db, invoice_id)
        if not invoice:
            return None

        if invoice.status != "pending":
            raise ValueError("Invoice must be pending to approve")

        invoice.status = "approved"
        invoice.approved_by_id = approver_id
        invoice.approved_at = datetime.utcnow()
        invoice.updated_at = datetime.utcnow()

        if notes:
            invoice.notes = notes

        db.commit()
        db.refresh(invoice)
        return invoice

    def send_invoice(self, db: Session, invoice_id: int) -> Optional[Invoice]:
        """Send invoice to supplier."""
        invoice = self.get_invoice(db, invoice_id)
        if not invoice:
            return None

        if invoice.status not in ["approved", "draft"]:
            raise ValueError("Invoice must be approved or draft to send")

        invoice.status = "sent"
        invoice.sent_at = datetime.utcnow()
        invoice.updated_at = datetime.utcnow()

        db.commit()
        db.refresh(invoice)
        return invoice

    def record_payment(
        self, db: Session, payment: PaymentCreate, recorded_by_id: int
    ) -> InvoicePayment:
        """Record payment for invoice."""
        invoice = self.get_invoice(db, payment.invoice_id)
        if not invoice:
            raise ValueError("Invoice not found")

        if invoice.status in ["cancelled", "disputed"]:
            raise ValueError("Cannot record payment for cancelled or disputed invoice")

        if payment.amount > invoice.remaining_amount:
            raise ValueError("Payment amount exceeds remaining amount")

        # Create payment
        db_payment = InvoicePayment(
            **payment.dict(),
            status="completed",
            recorded_by_id=recorded_by_id,
            created_at=datetime.utcnow()
        )

        db.add(db_payment)

        # Update invoice
        invoice.paid_amount += payment.amount
        invoice.remaining_amount = invoice.total_amount - invoice.paid_amount

        if invoice.remaining_amount <= 0:
            invoice.status = "paid"
            invoice.paid_at = datetime.utcnow()

        invoice.updated_at = datetime.utcnow()

        db.commit()
        db.refresh(db_payment)
        return db_payment

    def mark_overdue(self, db: Session, invoice_id: int) -> Optional[Invoice]:
        """Mark invoice as overdue."""
        invoice = self.get_invoice(db, invoice_id)
        if not invoice:
            return None

        if invoice.status in ["paid", "cancelled", "disputed"]:
            return invoice

        if invoice.due_date < date.today():
            invoice.status = "overdue"
            invoice.updated_at = datetime.utcnow()
            db.commit()
            db.refresh(invoice)

        return invoice

    def dispute_invoice(
        self, db: Session, invoice_id: int, dispute_reason: str, disputed_by_id: int
    ) -> Optional[Invoice]:
        """Dispute invoice."""
        invoice = self.get_invoice(db, invoice_id)
        if not invoice:
            return None

        if invoice.status in ["paid", "cancelled"]:
            raise ValueError("Cannot dispute paid or cancelled invoice")

        invoice.status = "disputed"
        invoice.dispute_reason = dispute_reason
        invoice.disputed_by_id = disputed_by_id
        invoice.disputed_at = datetime.utcnow()
        invoice.updated_at = datetime.utcnow()

        db.commit()
        db.refresh(invoice)
        return invoice

    def cancel_invoice(
        self, db: Session, invoice_id: int, reason: str, cancelled_by_id: int
    ) -> Optional[Invoice]:
        """Cancel invoice."""
        invoice = self.get_invoice(db, invoice_id)
        if not invoice:
            return None

        if invoice.status == "paid":
            raise ValueError("Cannot cancel paid invoice")

        invoice.status = "cancelled"
        invoice.cancellation_reason = reason
        invoice.cancelled_by_id = cancelled_by_id
        invoice.cancelled_at = datetime.utcnow()
        invoice.updated_at = datetime.utcnow()

        db.commit()
        db.refresh(invoice)
        return invoice

    def get_invoice_statistics(
        self, db: Session, supplier_id: Optional[int] = None, project_id: Optional[int] = None
    ) -> Dict[str, Any]:
        """Get invoice statistics."""
        query = db.query(Invoice)
        
        if supplier_id:
            query = query.filter(Invoice.supplier_id == supplier_id)
        if project_id:
            query = query.filter(Invoice.project_id == project_id)

        total_invoices = query.count()
        
        # Count by status
        status_counts = {}
        for status in ["draft", "pending", "approved", "sent", "paid", "overdue", "cancelled", "disputed"]:
            count = query.filter(Invoice.status == status).count()
            status_counts[f"{status}_count"] = count

        # Financial statistics
        total_amount = query.with_entities(func.sum(Invoice.total_amount)).scalar() or 0
        total_paid = query.with_entities(func.sum(Invoice.paid_amount)).scalar() or 0
        total_remaining = total_amount - total_paid
        avg_amount = query.with_entities(func.avg(Invoice.total_amount)).scalar() or 0

        # Overdue statistics
        overdue_query = query.filter(
            and_(
                Invoice.due_date < date.today(),
                Invoice.status.in_(["pending", "approved", "sent"])
            )
        )
        overdue_count = overdue_query.count()
        overdue_amount = overdue_query.with_entities(func.sum(Invoice.remaining_amount)).scalar() or 0

        return {
            "total_invoices": total_invoices,
            **status_counts,
            "total_amount": total_amount,
            "total_paid": total_paid,
            "total_remaining": total_remaining,
            "average_amount": avg_amount,
            "overdue_count": overdue_count,
            "overdue_amount": overdue_amount
        }

    def check_overdue_invoices(self, db: Session) -> List[Invoice]:
        """Check for overdue invoices (scheduled task)."""
        overdue_invoices = db.query(Invoice).filter(
            and_(
                Invoice.due_date < date.today(),
                Invoice.status.in_(["pending", "approved", "sent"])
            )
        ).all()

        for invoice in overdue_invoices:
            invoice.status = "overdue"
            invoice.updated_at = datetime.utcnow()

        db.commit()
        return overdue_invoices

    def send_payment_reminders(self, db: Session) -> List[Invoice]:
        """Send payment reminders (scheduled task)."""
        # Get invoices that are overdue or due soon
        reminder_date = date.today() + timedelta(days=7)  # 7 days before due
        
        invoices_to_remind = db.query(Invoice).filter(
            and_(
                Invoice.due_date <= reminder_date,
                Invoice.status.in_(["sent", "overdue"]),
                Invoice.remaining_amount > 0
            )
        ).all()

        # In a real implementation, this would send actual emails/SMS
        # For now, we'll just log the action
        for invoice in invoices_to_remind:
            # Update last reminder date
            invoice.last_reminder_at = datetime.utcnow()
            invoice.updated_at = datetime.utcnow()

        db.commit()
        return invoices_to_remind

    def generate_invoice_pdf(self, db: Session, invoice_id: int) -> bytes:
        """Generate PDF for invoice."""
        # This would integrate with a PDF generation library like ReportLab
        # For now, return empty bytes
        return b""

    def get_invoice_by_number(self, db: Session, invoice_number: str) -> Optional[Invoice]:
        """Get invoice by invoice number."""
        return (
            db.query(Invoice)
            .options(
                joinedload(Invoice.supplier),
                joinedload(Invoice.project),
                joinedload(Invoice.items),
                joinedload(Invoice.payments)
            )
            .filter(Invoice.invoice_number == invoice_number)
            .first()
        )
