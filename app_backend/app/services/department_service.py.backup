"""
Department Service
"""
from typing import Optional, List, Tuple
from sqlalchemy.orm import Session

from app.models.department import Department
from app.schemas.department import DepartmentCreate, DepartmentUpdate, DepartmentSearch
from app.services.base_service import BaseService
from app.core.exceptions import DuplicateException


class DepartmentService(BaseService[Department]):
    
    def __init__(self):
        super().__init__(Department)
    
    def list_with_filters(self, db: Session, filters: DepartmentSearch) -> Tuple[List[Department], int]:
        query = self._base_query(db)
        
        if filters.name:
            query = query.where(Department.name.ilike(f"%{filters.name}%"))
        if filters.is_active is not None:
            query = query.where(Department.is_active == filters.is_active)
        
        total = self.count(db, is_active=filters.is_active)
        
        offset = (filters.page - 1) * filters.page_size
        departments = db.execute(query.offset(offset).limit(filters.page_size)).scalars().all()
        
        return departments, total
    
    def create_department(self, db: Session, dept_data: DepartmentCreate) -> Department:
        return self.create(db, dept_data.model_dump())
    
    def update_department(self, db: Session, dept_id: int, dept_data: DepartmentUpdate) -> Department:
        return self.update(db, dept_id, dept_data.model_dump(exclude_unset=True, exclude_none=True))


department_service = DepartmentService()
