# =============================================================================
# Standard Breakdown Schema - פירוק תקני
# =============================================================================

class StandardBreakdownConfig(BaseModel):
    """
    Configuration for standard breakdown
    לפי נהלי קק"ל:
    - 2 שעות עבודה
    - 30 דקות הפסקה
    - חוזר עד 9 שעות עבודה + 1.5 שעות הפסקה = 10.5 שעות סה"כ
    """
    work_segment_minutes: int = Field(120, description="דקות עבודה בכל מקטע")
    break_segment_minutes: int = Field(30, description="דקות הפסקה בין מקטעים")
    max_work_hours: Decimal = Field(Decimal("9.0"), description="מקסימום שעות עבודה")
    max_break_hours: Decimal = Field(Decimal("1.5"), description="מקסימום שעות הפסקה")
    max_total_hours: Decimal = Field(Decimal("10.5"), description="מקסימום סה״כ")
    start_time: time = Field(default_factory=lambda: time(6, 30),
                             description="שעת התחלה ברירת מחדל")


