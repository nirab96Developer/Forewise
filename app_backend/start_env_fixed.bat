REM Check prerequisites using the correct commands
echo ūüĒć Checking prerequisites...
py --version >nul 2>&1
if errorlevel 1 (
    echo ‚ĚĆ Python is not installed or not in PATH
    echo Please install Python and try again
    pause
    exit /b 1
) else (
    echo ‚úÖ Python is installed
)

node --version >nul 2>&1
if errorlevel 1 (
    echo ‚ĚĆ Node.js is not installed or not in PATH
    echo Please install Node.js and try again
    pause
    exit /b 1
) else (
    echo ‚úÖ Node.js is installed
)

npm --version >nul 2>&1
if errorlevel 1 (
    echo ‚ĚĆ npm is not installed or not in PATH
    echo Please install npm and try again
    pause
    exit /b 1
) else (
    echo ‚úÖ npm is installed
)

echo.

REM Check directories
if not exist "C:\ForestProject\app_backend" (
    echo ‚ĚĆ Backend directory not found: C:\ForestProject\app_backend
    pause
    exit /b 1
) else (
    echo ‚úÖ Backend directory found
)

if not exist "C:\ForestProject\app_frontend" (
    echo ‚ĚĆ Frontend directory not found: C:\ForestProject\app_frontend
    pause
    exit /b 1
) else (
    echo ‚úÖ Frontend directory found
)

echo.

REM Clean up existing processes
echo ūüßĻ Cleaning up existing processes...
for /f "tokens=5" %%a in ('netstat -aon ^| findstr :8000') do taskkill /f /pid %%a >nul 2>&1
for /f "tokens=5" %%a in ('netstat -aon ^| findstr :3000') do taskkill /f /pid %%a >nul 2>&1
for /f "tokens=5" %%a in ('netstat -aon ^| findstr :3001') do taskkill /f /pid %%a >nul 2>&1
echo ‚úÖ Cleanup completed
echo.

REM Start Backend Server
echo ūüöÄ Starting Backend Server...
echo ========================================
start "Backend Server" cmd /k "cd /d C:\ForestProject\app_backend && echo Starting Backend Server... && py run.py"

REM Wait for backend
echo ‚Ź≥ Waiting for backend to start...
ping 127.0.0.1 -n 6 >nul

REM Check if backend is running
netstat -an | findstr :8000 >nul
if errorlevel 1 (
    echo ‚ĚĆ Backend server failed to start
    echo Please check the backend logs
    pause
    exit /b 1
) else (
    echo ‚úÖ Backend server is running on port 8000
)

echo.

REM Start Frontend Server
echo ūüĆź Starting Frontend Development Server...
echo ========================================
start "Frontend Server" cmd /k "cd /d C:\ForestProject\app_frontend && echo Starting Frontend Server... && npm run dev"

REM Wait for frontend
echo ‚Ź≥ Waiting for frontend to start...
ping 127.0.0.1 -n 11 >nul

REM Check which port frontend is using
set FRONTEND_PORT=3000
netstat -an | findstr :3000 >nul
if errorlevel 1 (
    set FRONTEND_PORT=3001
    netstat -an | findstr :3001 >nul
    if errorlevel 1 (
        echo ‚ö†ÔłŹ  Frontend server may still be starting...
        set FRONTEND_PORT=3000
    ) else (
        echo ‚úÖ Frontend server is running on port 3001
    )
) else (
    echo ‚úÖ Frontend server is running on port 3000
)

echo.

REM Start Electron App
echo ūüĖ•ÔłŹ  Starting Electron App...
echo ========================================
start "Electron App" cmd /k "cd /d C:\ForestProject\app_frontend && echo Starting Electron App... && npm run electron:preview"

echo.
echo ========================================
echo ūüéČ All services started successfully!
echo ========================================
