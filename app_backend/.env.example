# Forest Management System - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Application Settings
APP_NAME="Forest Management System"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT="development"

# API Settings
API_V1_STR="/api/v1"
PROJECT_NAME="Forest Management System"
VERSION="1.0.0"
DESCRIPTION="Comprehensive forest management and reporting system"

# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/forest_db"

# Security
SECRET_KEY="your_secret_key_here"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Server Configuration
HOST="127.0.0.1"
PORT=8000
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Email Configuration
SMTP_TLS=true
SMTP_PORT=587
SMTP_HOST="smtp.gmail.com"
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_smtp_password_here"

# Admin User (for initial setup)
FIRST_SUPERUSER_EMAIL="admin@forest-system.com"
FIRST_SUPERUSER_PASSWORD="Admin123!"

# File Upload Settings
MAX_FILE_SIZE_MB=10
UPLOAD_DIR="uploads"

# Performance Settings
CACHE_TTL=300
REDIS_URL="redis://localhost:6379"

# External APIs
GOOGLE_MAPS_API_KEY="your_google_maps_api_key"

# Logging
LOG_LEVEL="INFO"
LOG_FILE="logs/development.log"

# Business Settings
DEFAULT_CURRENCY="ILS"
DEFAULT_LANGUAGE="he"
DEFAULT_TIMEZONE="Asia/Jerusalem"
